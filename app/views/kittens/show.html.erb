<h1><%= @kitten.name %></h1>

<p><strong>Age:</strong> <%= @kitten.age %></p>
<p><strong>Cuteness:</strong> <%= @kitten.cuteness %></p>
<p><strong>Softness:</strong> <%= @kitten.softness %></p>

<%= link_to "Edit this Kitten", edit_kitten_path(@kitten) %> |
<%= link_to "Back to Kittens", kittens_path %> |
<%= button_to "Delete this Kitten", @kitten, method: :delete, data: { turbo_confirm: 'Are you sure?' } %>